<% const isFr = typeof lang !== 'undefined' && lang === 'fr'; %>
<%- include('../layouts/main', { body: `
<div class="course-detail-page">
    <div class="course-hero">
        <div class="container">
            <nav class="breadcrumb-nav" aria-label="Breadcrumb">
                <ol class="breadcrumb-list">
                    <li class="breadcrumb-item"><a href="/">${isFr ? 'Accueil' : 'Home'}</a></li>
                    <li class="breadcrumb-item"><a href="/courses">${isFr ? 'Parcours' : 'Courses'}</a></li>
                    <li class="breadcrumb-item"><a href="/courses?department=${course.department}">${course.department_name}</a></li>
                    <li class="breadcrumb-item active"><span>${course.name}</span></li>
                </ol>
            </nav>
            <h1>${course.name}</h1>
            ${course.photos && course.photos.length > 0 ? `
                <div class="course-hero-image">
                    <img src="${course.photos[0]}" alt="${course.name}" loading="eager">
                </div>
            ` : ''}
            <p class="course-hero-location">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                ${course.city}, ${course.department_name}
            </p>
            ${course.reviews && course.reviews.length > 0 ? `
                <div class="course-hero-rating">
                    <span class="stars">${'★'.repeat(Math.round(course.reviews.reduce((a, r) => a + r.rating, 0) / course.reviews.length))}${'☆'.repeat(5 - Math.round(course.reviews.reduce((a, r) => a + r.rating, 0) / course.reviews.length))}</span>
                    <span>${course.reviews.length} ${isFr ? (course.reviews.length === 1 ? 'avis' : 'avis') : (course.reviews.length === 1 ? 'review' : 'reviews')}</span>
                </div>
            ` : ''}
        </div>
    </div>

    <div class="container">
        <div class="course-content">
            <div class="course-main">
                <section class="course-section">
                    <h2>${isFr ? 'À Propos de ce Parcours' : 'About This Course'}</h2>
                    <p class="course-description">${course.description || (isFr ? 'Aucune description disponible.' : 'No description available.')}</p>
                </section>

                <section class="course-section">
                    <h2>${isFr ? 'Détails du Parcours' : 'Course Details'}</h2>
                    <div class="course-stats">
                        <div class="stat-card">
                            <span class="stat-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                            </span>
                            <span class="stat-value">${course.holes}</span>
                            <span class="stat-label">${isFr ? 'Trous' : 'Holes'}</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                            </span>
                            <span class="stat-value">${course.par}</span>
                            <span class="stat-label">Par</span>
                        </div>
                        ${course.course_length_meters ? `
                            <div class="stat-card">
                                <span class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                                </span>
                                <span class="stat-value">${course.course_length_meters}m</span>
                                <span class="stat-label">${isFr ? 'Longueur' : 'Length'}</span>
                            </div>
                        ` : ''}
                        ${course.slope_rating ? `
                            <div class="stat-card">
                                <span class="stat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                                </span>
                                <span class="stat-value">${course.slope_rating}</span>
                                <span class="stat-label">Slope</span>
                            </div>
                        ` : ''}
                    </div>
                    <div class="details-grid course-meta">
                        ${course.architect ? `
                            <div class="detail-item">
                                <span class="detail-label">${isFr ? 'Architecte' : 'Architect'}</span>
                                <span class="detail-value">${course.architect}</span>
                            </div>
                        ` : ''}
                        ${course.year_opened ? `
                            <div class="detail-item">
                                <span class="detail-label">${isFr ? 'Ouverture' : 'Opened'}</span>
                                <span class="detail-value">${course.year_opened}</span>
                            </div>
                        ` : ''}
                        ${course.course_rating ? `
                            <div class="detail-item">
                                <span class="detail-label">${isFr ? 'Rating du Parcours' : 'Course Rating'}</span>
                                <span class="detail-value">${course.course_rating}</span>
                            </div>
                        ` : ''}
                        ${course.max_handicap ? `
                            <div class="detail-item">
                                <span class="detail-label">${isFr ? 'Handicap Max' : 'Max Handicap'}</span>
                                <span class="detail-value">${course.max_handicap}</span>
                            </div>
                        ` : ''}
                    </div>
                </section>

                <section class="course-section">
                    <h2>${isFr ? 'Équipements' : 'Facilities'}</h2>
                    <div class="facilities-grid-icons">
                        ${course.driving_range ? `
                            <div class="facility-item">
                                <span class="facility-icon">🎯</span>
                                <span>${isFr ? 'Practice' : 'Driving Range'}</span>
                            </div>
                        ` : ''}
                        ${course.putting_green ? `
                            <div class="facility-item">
                                <span class="facility-icon">⛳</span>
                                <span>${isFr ? 'Putting Green' : 'Putting Green'}</span>
                            </div>
                        ` : ''}
                        ${course.chipping_green ? `
                            <div class="facility-item">
                                <span class="facility-icon">🏌️</span>
                                <span>${isFr ? 'Chipping Green' : 'Chipping Green'}</span>
                            </div>
                        ` : ''}
                        ${course.practice_bunker ? `
                            <div class="facility-item">
                                <span class="facility-icon">🏖️</span>
                                <span>${isFr ? 'Bunker de Practice' : 'Practice Bunker'}</span>
                            </div>
                        ` : ''}
                        ${course.buggy_available ? `
                            <div class="facility-item">
                                <span class="facility-icon">🚗</span>
                                <span>${isFr ? 'Location Voiturette' : 'Buggy Rental'}</span>
                            </div>
                        ` : ''}
                        ${course.trolley_available ? `
                            <div class="facility-item">
                                <span class="facility-icon">🛒</span>
                                <span>${isFr ? 'Location Chariot' : 'Trolley Rental'}</span>
                            </div>
                        ` : ''}
                        ${course.club_rental ? `
                            <div class="facility-item">
                                <span class="facility-icon">🏒</span>
                                <span>${isFr ? 'Location Clubs' : 'Club Rental'}</span>
                            </div>
                        ` : ''}
                        ${course.pro_shop ? `
                            <div class="facility-item">
                                <span class="facility-icon">🛍️</span>
                                <span>${isFr ? 'Pro Shop' : 'Pro Shop'}</span>
                            </div>
                        ` : ''}
                        ${course.golf_lessons ? `
                            <div class="facility-item">
                                <span class="facility-icon">📚</span>
                                <span>${isFr ? 'Cours de Golf' : 'Golf Lessons'}</span>
                            </div>
                        ` : ''}
                        ${course.restaurant ? `
                            <div class="facility-item">
                                <span class="facility-icon">🍽️</span>
                                <span>${isFr ? 'Restaurant' : 'Restaurant'}</span>
                            </div>
                        ` : ''}
                        ${course.hotel_onsite ? `
                            <div class="facility-item">
                                <span class="facility-icon">🏨</span>
                                <span>${isFr ? 'Hôtel sur Place' : 'Hotel On-site'}</span>
                            </div>
                        ` : ''}
                        ${course.spa ? `
                            <div class="facility-item">
                                <span class="facility-icon">💆</span>
                                <span>${isFr ? 'Spa' : 'Spa'}</span>
                            </div>
                        ` : ''}
                        ${course.swimming_pool ? `
                            <div class="facility-item">
                                <span class="facility-icon">🏊</span>
                                <span>${isFr ? 'Piscine' : 'Swimming Pool'}</span>
                            </div>
                        ` : ''}
                        ${course.caddy_available ? `
                            <div class="facility-item">
                                <span class="facility-icon">🧑</span>
                                <span>${isFr ? 'Service Caddy' : 'Caddy Service'}</span>
                            </div>
                        ` : ''}
                    </div>
                </section>

                ${course.signature_holes ? `
                    <section class="course-section">
                        <h2>${isFr ? 'Trous Signature' : 'Signature Holes'}</h2>
                        <p>${course.signature_holes}</p>
                    </section>
                ` : ''}

                ${course.insider_tips ? `
                    <section class="course-section insider-tips">
                        <h2>${isFr ? 'Conseils d\'Initié' : 'Insider Tips'}</h2>
                        <div class="tip-box">
                            <span class="tip-icon">💡</span>
                            <p>${course.insider_tips}</p>
                        </div>
                    </section>
                ` : ''}

                ${course.green_fee_info ? `
                    <section class="course-section">
                        <h2>${isFr ? 'Green Fees' : 'Green Fees'}</h2>
                        <p>${course.green_fee_info}</p>
                    </section>
                ` : ''}

                ${course.dress_code ? `
                    <section class="course-section">
                        <h2>${isFr ? 'Code Vestimentaire' : 'Dress Code'}</h2>
                        <p>${course.dress_code}</p>
                    </section>
                ` : ''}

                ${course.booking_info ? `
                    <section class="course-section">
                        <h2>${isFr ? 'Réservations' : 'Booking Information'}</h2>
                        <p>${course.booking_info}</p>
                    </section>
                ` : ''}

                <section class="course-section reviews-section">
                    <div class="section-header">
                        <h2>${isFr ? 'Avis' : 'Reviews'} ${course.reviews && course.reviews.length > 0 ? `(${course.reviews.length})` : ''}</h2>
                        ${typeof user !== 'undefined' && user ? `
                            <a href="/courses/${course.slug}/review" class="btn btn-outline btn-sm">${isFr ? 'Donner un Avis' : 'Write a Review'}</a>
                        ` : `
                            <a href="/auth/login?redirect=/courses/${course.slug}/review" class="btn btn-outline btn-sm">${isFr ? 'Connexion pour Avis' : 'Login to Review'}</a>
                        `}
                    </div>
                    ${course.reviews && course.reviews.length > 0 ? `
                        <div class="reviews-summary">
                            <div class="avg-rating">
                                <span class="avg-number">${(course.reviews.reduce((a, r) => a + r.rating, 0) / course.reviews.length).toFixed(1)}</span>
                                <span class="avg-stars">${'★'.repeat(Math.round(course.reviews.reduce((a, r) => a + r.rating, 0) / course.reviews.length))}</span>
                            </div>
                        </div>
                        <div class="reviews-list">
                            ${course.reviews.map(review => `
                                <div class="review-card">
                                    <div class="review-header">
                                        <div class="review-author">
                                            ${review.profile_photo ?
                                                `<img src="${review.profile_photo}" alt="" class="review-avatar">` :
                                                `<span class="review-avatar-placeholder">${review.display_name.charAt(0)}</span>`
                                            }
                                            <div class="review-author-info">
                                                <span class="author-name">${review.display_name}</span>
                                                ${review.date_played ? `<span class="review-date">${isFr ? 'Joué en' : 'Played'} ${new Date(review.date_played).toLocaleDateString(isFr ? 'fr-FR' : 'en-GB', { month: 'short', year: 'numeric' })}</span>` : ''}
                                            </div>
                                        </div>
                                        <div class="review-rating">
                                            ${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}
                                        </div>
                                    </div>
                                    ${review.title ? `<h4 class="review-title">${review.title}</h4>` : ''}
                                    <p class="review-content">${review.content}</p>
                                    ${review.course_condition || review.value_for_money || review.facilities || review.scenery ? `
                                        <div class="review-breakdown">
                                            ${review.course_condition ? `<span>${isFr ? 'État' : 'Condition'}: ${'★'.repeat(review.course_condition)}</span>` : ''}
                                            ${review.value_for_money ? `<span>${isFr ? 'Rapport qualité-prix' : 'Value'}: ${'★'.repeat(review.value_for_money)}</span>` : ''}
                                            ${review.facilities ? `<span>${isFr ? 'Équipements' : 'Facilities'}: ${'★'.repeat(review.facilities)}</span>` : ''}
                                            ${review.scenery ? `<span>${isFr ? 'Paysage' : 'Scenery'}: ${'★'.repeat(review.scenery)}</span>` : ''}
                                        </div>
                                    ` : ''}
                                </div>
                            `).join('')}
                        </div>
                    ` : `
                        <div class="empty-state">
                            <p>${isFr ? 'Pas encore d\'avis. Soyez le premier à partager votre expérience !' : 'No reviews yet. Be the first to share your experience!'}</p>
                        </div>
                    `}
                </section>
            </div>

            <aside class="course-sidebar">
                <div class="card course-actions-card">
                    <h3>${isFr ? 'Jouer Ici' : 'Play Here'}</h3>
                    <a href="/games?course=${course.id}" class="btn btn-primary btn-block">${isFr ? 'Trouver une Partie' : 'Find a Game'}</a>
                    <a href="/games/create?course=${course.id}" class="btn btn-outline btn-block">${isFr ? 'Créer une Partie' : 'Create a Game'}</a>
                </div>

                <div class="card course-contact-card">
                    <h3>${isFr ? 'Contact' : 'Contact'}</h3>
                    ${course.phone ? `
                        <div class="contact-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            <a href="tel:${course.phone}">${course.phone}</a>
                        </div>
                    ` : ''}
                    ${course.email ? `
                        <div class="contact-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <a href="mailto:${course.email}">${course.email}</a>
                        </div>
                    ` : ''}
                    ${course.website ? `
                        <div class="contact-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                            <a href="${course.website}" target="_blank" rel="noopener">${course.website.replace('https://', '').replace('http://', '')}</a>
                        </div>
                    ` : ''}
                    ${course.address ? `
                        <div class="contact-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            <span>${course.address}</span>
                        </div>
                    ` : ''}
                </div>

                ${course.latitude && course.longitude ? `
                    <div class="card">
                        <h3>${isFr ? 'Localisation' : 'Location'}</h3>
                        <div id="course-map" class="course-map" data-lat="${course.latitude}" data-lng="${course.longitude}" data-name="${course.name}" data-address="${course.address || ''}"></div>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(course.address || course.latitude + ',' + course.longitude)}" target="_blank" rel="noopener" class="btn btn-outline btn-block btn-sm">${isFr ? 'Itinéraire' : 'Get Directions'}</a>
                    </div>
                ` : ''}

                <div class="card nearby-card">
                    <h3>${isFr ? 'Jouer avec d\'Autres' : 'Play With Others'}</h3>
                    <p class="text-muted">${isFr ? 'Vous cherchez des partenaires à ' + course.name + ' ?' : 'Looking for playing partners at ' + course.name + '?'}</p>
                    <a href="/available?course=${course.id}" class="btn btn-outline btn-block btn-sm">${isFr ? 'Trouver des Joueurs' : 'Find Available Players'}</a>
                </div>

                ${typeof relatedCourses !== 'undefined' && relatedCourses && relatedCourses.length > 0 ? `
                <div class="card related-courses-card">
                    <h3>${isFr ? 'Parcours à Proximité' : 'Nearby Courses'}</h3>
                    <ul class="related-courses-list">
                        ${relatedCourses.map(rc => `
                            <li>
                                <a href="/courses/${rc.slug}">
                                    <span class="rc-name">${rc.name}</span>
                                    <span class="rc-meta">${rc.city} • ${rc.holes} ${isFr ? 'trous' : 'holes'}</span>
                                    ${parseFloat(rc.avg_rating) > 0 ? `<span class="rc-rating">${'★'.repeat(Math.round(parseFloat(rc.avg_rating)))}</span>` : ''}
                                </a>
                            </li>
                        `).join('')}
                    </ul>
                    <a href="/courses?department=${course.department}" class="btn btn-outline btn-block btn-sm">${isFr ? 'Tous les Parcours ' + course.department_name : 'All ' + course.department_name + ' Courses'}</a>
                </div>
                ` : ''}
            </aside>
        </div>
    </div>
</div>

<script>
// Initialize map if coordinates available
document.addEventListener('DOMContentLoaded', function() {
    const mapEl = document.getElementById('course-map');
    if (mapEl && typeof L !== 'undefined') {
        const lat = parseFloat(mapEl.dataset.lat);
        const lng = parseFloat(mapEl.dataset.lng);
        const name = mapEl.dataset.name;
        const address = mapEl.dataset.address;

        const map = L.map('course-map').setView([lat, lng], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        const popupContent = address
            ? '<strong>' + name + '</strong><br>' + address
            : '<strong>' + name + '</strong>';
        L.marker([lat, lng]).addTo(map).bindPopup(popupContent).openPopup();
    }
});
</script>
` }) %>
