<%- include('../layouts/main', { body: `
<div class="availability-page">
    <div class="container container-narrow">
        <h1>${t.availability.title}</h1>
        <p class="text-muted">${t.availability.subtitle}</p>

        <form action="/availability/create" method="POST" class="availability-form">
            <input type="hidden" name="_csrf" value="${csrfToken}">
            <section class="form-section">
                <h2>${t.availability.whenAvailable}</h2>

                <div class="form-group">
                    <label>${t.availability.dateType} *</label>
                    <div class="date-type-toggle">
                        <label class="radio-label">
                            <input type="radio" name="date_type" value="single" checked> ${t.availability.singleDay}
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="date_type" value="range"> ${t.availability.period}
                        </label>
                    </div>
                </div>

                <div class="form-group" id="single-date-group">
                    <label for="available_date">${t.availability.date} *</label>
                    <input type="text" id="available_date" name="available_date" placeholder="${t.availability.selectDate}">
                </div>

                <div class="form-row date-range-group" id="date-range-group" style="display: none;">
                    <div class="form-group">
                        <label for="start_date">${t.availability.from} *</label>
                        <input type="text" id="start_date" name="start_date" placeholder="${t.availability.startDate}">
                    </div>
                    <div class="form-group">
                        <label for="end_date">${t.availability.to} *</label>
                        <input type="text" id="end_date" name="end_date" placeholder="${t.availability.endDate}">
                    </div>
                </div>

                <div class="form-group">
                    <label for="time_window">${t.availability.timeWindow} *</label>
                    <select id="time_window" name="time_window" required>
                        <option value="">${t.profile.select}</option>
                        <option value="early_bird">${t.availability.earlyBird}</option>
                        <option value="morning">${t.availability.morning}</option>
                        <option value="afternoon">${t.availability.afternoon}</option>
                        <option value="all_day">${t.availability.allDay}</option>
                    </select>
                </div>
            </section>

            <section class="form-section">
                <h2>${t.availability.whereOptional}</h2>

                <div class="form-group">
                    <label>${t.availability.preferredCourse} 1</label>
                    <select name="course_ids" class="course-dropdown">
                        <option value="">${t.availability.anyCourse}</option>
                        ${courses.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
                    </select>
                </div>

                <div class="form-group">
                    <label>${t.availability.preferredCourse} 2 (${t.availability.optional})</label>
                    <select name="course_ids" class="course-dropdown">
                        <option value="">—</option>
                        ${courses.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
                    </select>
                </div>

                <div class="form-group">
                    <label>${t.availability.preferredCourse} 3 (${t.availability.optional})</label>
                    <select name="course_ids" class="course-dropdown">
                        <option value="">—</option>
                        ${courses.map(c => `<option value="${c.id}">${c.name}</option>`).join('')}
                    </select>
                </div>

                <div class="form-group">
                    <label for="area">${t.availability.area}</label>
                    <select id="area" name="area">
                        <option value="">${t.availability.anyArea}</option>
                        <option value="nice">Nice</option>
                        <option value="cannes">Cannes</option>
                        <option value="monaco">Monaco</option>
                        <option value="mougins">Mougins</option>
                        <option value="saint-tropez">Saint-Tropez</option>
                        <option value="grasse">Grasse</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="note">${t.availability.note}</label>
                    <textarea id="note" name="note" rows="2"
                              placeholder="${t.availability.notePlaceholder}"></textarea>
                </div>
            </section>

            <div class="form-actions">
                <a href="/dashboard" class="btn btn-outline">${t.common.cancel}</a>
                <button type="submit" class="btn btn-primary">${t.availability.setAvailability}</button>
            </div>
        </form>

        ${myAvailability && myAvailability.length > 0 ? `
            <section class="my-availability">
                <h2>${t.availability.yourCurrentAvailability}</h2>
                <div class="availability-list">
                    ${myAvailability.map(avail => `
                        <div class="availability-item">
                            <div class="avail-info">
                                <strong>${new Date(avail.available_date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', { weekday: 'short', day: 'numeric', month: 'short' })}</strong>
                                <span>${avail.time_window.replace('_', ' ')}</span>
                                ${avail.course_name ? `<span>@ ${avail.course_name}</span>` : ''}
                            </div>
                            <form action="/availability/${avail.id}/delete" method="POST">
                                <input type="hidden" name="_csrf" value="${csrfToken}">
                                <button type="submit" class="btn btn-outline btn-sm">${t.availability.remove}</button>
                            </form>
                        </div>
                    `).join('')}
                </div>
            </section>
        ` : ''}
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
.availability-page { padding: var(--spacing-2xl) 0; }
.availability-page h1 { margin-bottom: var(--spacing-xs); }
.availability-page > .container > p { margin-bottom: var(--spacing-xl); }
.my-availability { margin-top: var(--spacing-2xl); padding-top: var(--spacing-2xl); border-top: 1px solid var(--color-border); }
.my-availability h2 { margin-bottom: var(--spacing-lg); }
.availability-list { display: flex; flex-direction: column; gap: var(--spacing-md); }
.availability-item { display: flex; justify-content: space-between; align-items: center; padding: var(--spacing-md); background: var(--color-bg-alt); border-radius: var(--radius-md); }
.avail-info { display: flex; gap: var(--spacing-md); align-items: center; flex-wrap: wrap; }
.avail-info span { color: var(--color-text-muted); text-transform: capitalize; }

/* Date type toggle */
.date-type-toggle { display: flex; gap: var(--spacing-lg); }
.radio-label { display: flex; align-items: center; gap: var(--spacing-sm); cursor: pointer; }
.radio-label input { width: auto; }

/* Date inputs */
#available_date, #start_date, #end_date {
    padding: 14px 16px;
    font-size: 16px;
    border: 1px solid var(--color-border, #E0E0E0);
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
    width: 100%;
}

/* Course dropdowns */
.course-dropdown {
    width: 100%;
    padding: 12px 16px;
    font-size: 16px;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    background: #fff;
    cursor: pointer;
}

/* Flatpickr */
.flatpickr-calendar { font-size: 16px !important; width: 340px !important; }
.flatpickr-day { width: 44px !important; height: 44px !important; line-height: 44px !important; font-size: 16px !important; }
.flatpickr-weekday { font-size: 14px !important; }
.flatpickr-current-month { font-size: 18px !important; }
.flatpickr-day.selected { background: var(--color-primary, #1B5E20) !important; border-color: var(--color-primary, #1B5E20) !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize Flatpickr
    flatpickr("#available_date", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d/m/Y",
        minDate: "today"
    });

    const startDatePicker = flatpickr("#start_date", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d/m/Y",
        minDate: "today",
        onChange: function(dates) {
            if (dates[0]) {
                endDatePicker.set('minDate', dates[0]);
            }
        }
    });

    const endDatePicker = flatpickr("#end_date", {
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d/m/Y",
        minDate: "today"
    });

    // Date type toggle
    const dateTypeRadios = document.querySelectorAll('input[name="date_type"]');
    const singleDateGroup = document.getElementById('single-date-group');
    const dateRangeGroup = document.getElementById('date-range-group');

    dateTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            if (this.value === 'single') {
                singleDateGroup.style.display = 'block';
                dateRangeGroup.style.display = 'none';
            } else {
                singleDateGroup.style.display = 'none';
                dateRangeGroup.style.display = 'flex';
            }
        });
    });

});
</script>
` }) %>
