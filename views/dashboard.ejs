<%
const launchT = t.launch || {
    foundingMemberBadge: lang === 'fr' ? 'Membre Fondateur' : 'Founding Member',
    countdownTitle: lang === 'fr' ? 'Lancement de la Plateforme' : 'Platform Launch Countdown',
    countdownSubtitle: lang === 'fr' ? 'Nous construisons notre communaute !' : 'We are building our community!',
    spotsLeft: lang === 'fr' ? '{count} places restantes' : '{count} spots left',
    youAreFoundingMember: lang === 'fr' ? 'Vous etes Membre Fondateur !' : 'You are a Founding Member!',
    foundingMemberPerks: lang === 'fr' ? 'En tant que membre fondateur, vous aurez toujours le badge.' : 'As a founding member, you will always have the badge.'
};
const emailNotVerified = lang === 'fr' ? 'Votre email n\'est pas verifie.' : 'Your email is not verified.';
const resendVerification = lang === 'fr' ? 'Renvoyer l\'email de verification' : 'Resend verification email';
%>
<%- include('layouts/main', { body: `
<div class="dashboard">
    <div class="container">
        <div class="dashboard-header">
            <h1>${t.dashboard.welcome}, ${user.display_name}!${user.is_founding_member ? ' <span class="founding-badge">' + launchT.foundingMemberBadge + '</span>' : ''}</h1>
            ${!user.email_verified ? `
                <div class="alert alert-warning">
                    <span>${emailNotVerified} <a href="/auth/resend-verification">${resendVerification}</a></span>
                </div>
            ` : ''}
        </div>

        ${!launchStatus.isLaunched ? `
            <section class="launch-countdown card">
                <div class="launch-countdown-content">
                    <h2>${launchT.countdownTitle}</h2>
                    <p class="launch-subtitle">${lang === 'fr' ? 'Les fonctionnalites de matching seront disponibles a ' + launchStatus.threshold + ' membres.' : 'Game matching features unlock at ' + launchStatus.threshold + ' members.'}</p>
                    <div class="launch-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${launchStatus.progressPercent}%"></div>
                        </div>
                        <div class="progress-text">
                            <span class="progress-count">${launchStatus.userCount} / ${launchStatus.threshold}</span>
                            <span class="progress-remaining">${lang === 'fr' ? launchStatus.spotsLeft + ' places restantes' : launchStatus.spotsLeft + ' spots left'}</span>
                        </div>
                    </div>
                    ${user.is_founding_member ? `
                        <p class="founding-member-notice">${launchT.youAreFoundingMember}</p>
                    ` : `
                        <p class="founding-member-notice">${lang === 'fr' ? 'Les ' + launchStatus.threshold + ' premiers membres recevront le badge Membre Fondateur.' : 'First ' + launchStatus.threshold + ' members will receive the Founding Member badge.'}</p>
                    `}
                </div>
            </section>
        ` : ''}

        <div class="dashboard-grid">
            <div class="dashboard-main">
                <section class="dashboard-section">
                    <h2>${t.dashboard.quickActions}</h2>
                    <div class="quick-actions">
                        ${launchStatus.isLaunched ? `
                            <a href="/games/create" class="action-card">
                                <div class="action-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                                </div>
                                <span>${t.dashboard.createGame}</span>
                            </a>
                            <a href="/availability/create" class="action-card">
                                <div class="action-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </div>
                                <span>${t.dashboard.setAvailability}</span>
                            </a>
                        ` : `
                            <div class="action-card locked">
                                <div class="action-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                </div>
                                <span>${t.dashboard.createGame}</span>
                                <span class="locked-label">${lang === 'fr' ? launchStatus.spotsLeft + ' places' : launchStatus.spotsLeft + ' spots left'}</span>
                            </div>
                            <div class="action-card locked">
                                <div class="action-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                </div>
                                <span>${t.dashboard.setAvailability}</span>
                                <span class="locked-label">${lang === 'fr' ? launchStatus.spotsLeft + ' places' : launchStatus.spotsLeft + ' spots left'}</span>
                            </div>
                        `}
                        <a href="/games" class="action-card">
                            <div class="action-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            </div>
                            <span>${t.dashboard.findGame}</span>
                        </a>
                        <a href="/available" class="action-card">
                            <div class="action-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <span>${t.dashboard.findPlayers}</span>
                        </a>
                    </div>
                </section>

                <section class="dashboard-section">
                    <div class="section-header">
                        <h2>${t.dashboard.upcomingGames}</h2>
                        <a href="/games/mine">${t.common.viewAll}</a>
                    </div>
                    ${typeof upcomingGames !== 'undefined' && upcomingGames && upcomingGames.length > 0 ?
                        `<div class="upcoming-games-list">
                            ${upcomingGames.map(game => `
                                <a href="/games/${game.id}" class="upcoming-game-card">
                                    <div class="game-date-small">
                                        <span class="date-num">${new Date(game.game_date).getDate()}</span>
                                        <span class="date-month">${new Date(game.game_date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', { month: 'short' })}</span>
                                    </div>
                                    <div class="game-info-small">
                                        <strong>${game.course_name}</strong>
                                        <span>${game.tee_time.slice(0, 5)}</span>
                                    </div>
                                </a>
                            `).join('')}
                        </div>` :
                        `<div class="empty-state">
                            <p>${t.dashboard.noUpcomingGames}. ${t.dashboard.browseGames}</p>
                        </div>`
                    }
                </section>

                ${typeof gamesToRate !== 'undefined' && gamesToRate && gamesToRate.length > 0 ? `
                    <section class="dashboard-section">
                        <h2>${lang === 'fr' ? 'Noter vos Partenaires' : 'Rate Your Partners'}</h2>
                        <div class="rate-games-list">
                            ${gamesToRate.map(game => `
                                <div class="rate-game-card">
                                    <div class="rate-game-info">
                                        <strong>${game.course_name}</strong>
                                        <span>${new Date(game.game_date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB')}</span>
                                    </div>
                                    <a href="/ratings/game/${game.id}" class="btn btn-primary btn-sm">${lang === 'fr' ? 'Noter' : 'Rate'}</a>
                                </div>
                            `).join('')}
                        </div>
                    </section>
                ` : ''}
            </div>

            <aside class="dashboard-sidebar">
                <div class="profile-summary card">
                    <div class="profile-summary-header">
                        ${user.profile_photo ?
                            `<img src="${user.profile_photo}" alt="" class="profile-avatar">` :
                            `<div class="profile-avatar-placeholder">${user.display_name.charAt(0).toUpperCase()}</div>`
                        }
                        <div>
                            <h3>${user.display_name}</h3>
                            <a href="/profile/edit" class="text-small">${t.dashboard.editProfile}</a>
                        </div>
                    </div>
                    <div class="profile-stats">
                        <div class="stat">
                            <span class="stat-value">${user.games_played || 0}</span>
                            <span class="stat-label">${lang === 'fr' ? 'Parties' : 'Games'}</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">${user.average_rating ? parseFloat(user.average_rating).toFixed(1) : '-'}</span>
                            <span class="stat-label">${lang === 'fr' ? 'Note' : 'Rating'}</span>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <h3>${t.dashboard.yourProfile}</h3>
                    <p class="text-muted">${t.dashboard.completeProfile}</p>
                    <a href="/profile/edit" class="btn btn-outline btn-block">${t.dashboard.editProfile}</a>
                </div>
            </aside>
        </div>
    </div>
</div>
` }) %>
