<%- include('../layouts/main', { body: `
<div class="guide-page">
    <div class="guide-hero">
        <div class="container">
            <nav class="breadcrumb-nav" aria-label="Breadcrumb">
                <ol class="breadcrumb-list">
                    <li class="breadcrumb-item"><a href="/">Accueil</a></li>
                    <li class="breadcrumb-item"><a href="/guides">Guides</a></li>
                    <li class="breadcrumb-item active"><span>Golf Pas Cher</span></li>
                </ol>
            </nav>
            <div class="guide-lang-switch">
                <a href="${alternateLang.url}" class="lang-link">${alternateLang.label}</a>
            </div>
            <h1>Golf Pas Cher sur la Côte d'Azur</h1>
            <p class="guide-hero-subtitle">Guide 2026</p>
            <p class="guide-hero-tagline">Parcours de golf abordables à moins de 80 €. La qualité sans se ruiner sur la Riviera.</p>
        </div>
    </div>

    <!-- Sticky CTA Banner -->
    <div class="sticky-cta-banner">
        <div class="container">
            <span>Vous cherchez des partenaires de jeu ?</span>
            <a href="/auth/register" class="btn btn-sm btn-primary">Rejoignez frenchriviera.golf — c'est gratuit</a>
        </div>
    </div>

    <div class="container">
        <div class="guide-content">
            <div class="guide-main">

                <!-- TL;DR Section -->
                <section class="guide-section guide-tldr">
                    <h2>En Bref</h2>
                    <div class="tldr-box">
                        <p>Pas besoin de dépenser 150 €+ pour jouer un excellent golf sur la Côte d'Azur. La <a href="/courses/grande-bastide">Grande Bastide</a> offre une qualité championship à partir de 55 € en basse saison — régulièrement classée parmi les meilleurs rapports qualité-prix de France. Le <a href="/courses/golf-club-biot">Golf de Biot</a> démarre à 45 € et se trouve à 15 minutes de Nice. Pour une partie rapide, le <a href="/courses/nice-golf-country-club">Nice Golf Country Club</a> propose 9 trous à partir de 25 €. Le secret : le timing. Novembre à février offre des tarifs 30-50% plus bas, et les départs twilight économisent 30-40%.</p>
                    </div>
                </section>

                <!-- Course List -->
                <section class="guide-section">
                    <h2>Meilleurs Golfs Abordables — Classement</h2>

                    ${courses.map((course, index) => `
                    <div class="ranked-course">
                        <div class="rank-badge">${course.position}</div>
                        <div class="ranked-course-content">
                            <h3><a href="/courses/${course.slug}">${course.name}</a> <span class="course-location">(${course.city})</span></h3>
                            <p>${course.description}</p>
                            <p class="course-details"><strong>Trous :</strong> ${course.holes} | <strong>Par :</strong> ${course.par} | <strong>Green Fee :</strong> ${course.greenFee} | <strong>Basse saison :</strong> ${course.lowSeason}</p>
                        </div>
                    </div>
                    `).join('')}

                </section>

                <!-- Comparison Table -->
                <section class="guide-section">
                    <h2>Comparatif des Prix</h2>
                    <div class="table-responsive">
                        <table class="guide-table">
                            <thead>
                                <tr>
                                    <th>Parcours</th>
                                    <th>Trous</th>
                                    <th>Basse Saison</th>
                                    <th>Haute Saison</th>
                                    <th>Twilight</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${courses.map(course => `
                                <tr>
                                    <td><a href="/courses/${course.slug}">${course.name}</a></td>
                                    <td>${course.holes}</td>
                                    <td>${course.lowSeason}</td>
                                    <td>${course.greenFee.split('-')[1] || course.greenFee}</td>
                                    <td>-30%</td>
                                </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- Tips Section -->
                <section class="guide-section">
                    <h2>Astuces pour Économiser</h2>
                    <ul class="tips-list">
                        <li><strong>Jouez en basse saison :</strong> Novembre à février offre les meilleurs tarifs (30-50% de réduction).</li>
                        <li><strong>Réservez en twilight :</strong> La plupart des parcours proposent des réductions 2-3h avant le coucher du soleil.</li>
                        <li><strong>Vérifiez les tarifs FFG :</strong> Les membres de la Fédération ont souvent des réductions.</li>
                        <li><strong>Réservez en semaine :</strong> Les tarifs sont généralement plus bas qu'en weekend.</li>
                        <li><strong>Forfaits multi-parcours :</strong> Certains parcours offrent des réductions pour plusieurs parties.</li>
                    </ul>
                </section>

                <!-- FAQ Section -->
                <section class="guide-section">
                    <h2>Questions Fréquentes</h2>
                    <div class="faq-list">
                        ${faqData.map(faq => `
                        <div class="faq-item">
                            <h3 class="faq-question">${faq.question}</h3>
                            <p class="faq-answer">${faq.answer}</p>
                        </div>
                        `).join('')}
                    </div>
                </section>

                <!-- CTA Section -->
                <section class="guide-section guide-cta-section">
                    <h2>Trouvez des Partenaires de Jeu</h2>
                    <p>Partagez les green fees en rejoignant un groupe. Utilisez frenchriviera.golf pour trouver des partenaires. C'est gratuit.</p>
                    <a href="/auth/register" class="btn btn-primary">Créer un Compte Gratuit</a>
                </section>

            </div>

            <!-- Sidebar -->
            <aside class="guide-sidebar">
                <div class="sidebar-card">
                    <h3>Infos Budget</h3>
                    <ul class="sidebar-stats">
                        <li><strong>18 trous le moins cher :</strong> 45 € (Biot)</li>
                        <li><strong>9 trous le moins cher :</strong> 25 € (Nice)</li>
                        <li><strong>Meilleur rapport qualité-prix :</strong> Grande Bastide</li>
                        <li><strong>Basse saison :</strong> Nov–Fév</li>
                    </ul>
                </div>
                <div class="sidebar-card">
                    <h3>Autres Guides</h3>
                    <ul class="sidebar-links">
                        <li><a href="/guides/meilleurs-golfs-cote-azur-2026">Meilleurs Golfs 2026</a></li>
                        <li><a href="/guides/golf-pres-aeroport-nice">Golfs près de l'Aéroport</a></li>
                        <li><a href="/guides/meilleurs-resorts-golf-cote-azur">Resorts Golf</a></li>
                    </ul>
                </div>
            </aside>
        </div>
    </div>
</div>
` }) %>
